<%- include('partials/navbar') %>

<main class="page">
    <section class="hero">
        <div>
            <p class="eyebrow">Marketplace</p>
            <h1>All Products</h1>
            <p class="subtle">Browse every product, filter by category, and save favorites from your dashboard.</p>
        </div>

        <% if (typeof user !== 'undefined' && user.role === 'admin') { %>
            <a class="button primary" href="/product/add">Add Product</a>
        <% } %>
    </section>

    <div class="toolbar">
        <form class="filter-form" method="GET" action="/products">
            <label for="category">
                Filter by category
                <select name="category" id="category">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat => { %>
                        <option value="<%= cat._id %>" <%= selectedCategory === cat._id.toString() ? 'selected' : '' %>><%= cat.name %></option>
                    <% }) %>
                </select>
            </label>
            <button class="button" type="submit">Apply</button>
        </form>
    </div>

    <% if (products.length === 0) { %>
        <section class="empty">
            <h2>No products found</h2>
            <p class="subtle">Try another category or ask an admin to add fresh stock.</p>
        </section>
    <% } else { %>
        <section class="grid">
            <% products.forEach(product => { %>
                <%- include('productItem', { product, user, favoriteIds }) %>
            <% }) %>
        </section>
    <% } %>
</main>
</body>
</html>
